{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "systemrdl",
      "camelcase": "SystemRDL",
      "title": "SystemRDL",
      "scope": "source.systemrdl",
      "file-types": [
        "rdl"
      ],
      "injection-regex": "^systemrdl$",
      "class-name": "TreeSitterSystemrdl"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "SystemRDL grammar for tree-sitter",
    "authors": [
      {
        "name": "Ayan Banerjee",
        "email": "ayanbanrj@gmail.com",
        "url": ""
      }
    ],
    "links": {
      "repository": "https://github.com/ayanbanrj/tree-sitter-systemrdl",
      "funding": ""
    }
  },
  "bindings": {
    "c": true,
    "go": false,
    "java": false,
    "node": true,
    "python": false,
    "rust": true,
    "swift": false,
    "zig": false
  }
}